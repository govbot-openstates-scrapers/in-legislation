{"legislative_session": "2026", "identifier": "HB 1265", "title": "Natural resource entrance fees.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["AGENCIES; Department of Natural Resources (DNR)", "NATURAL RESOURCES; State Parks"], "abstracts": [{"note": "Digest", "abstract": "Allows counties to adopt an ordinance to impose a surcharge of not more than $2 in addition to the fees charged by the department of natural resources (department) for entry into state parks and state recreation areas. Requires the department to collect the surcharge and to report and pay the surcharge to each county treasurer. Provides that the revenue collected is to be used for purposes related to first responders and infrastructure improvements. Provides that the surcharge may not be imposed on a person who holds an annual pass."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-hb1265"}], "actions": [{"description": "First reading: referred to Committee on Natural Resources", "date": "2026-01-06", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Natural Resources", "entity_type": "organization", "organization_id": null}]}, {"description": "Authored by Representative Yocum", "date": "2026-01-06", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name": "Tim Yocum", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Tim Yocum\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "Introduced House Bill (H)", "links": [{"url": "https://iga.in.gov/pdf-documents/124/2026/house/bills/HB1265/HB1265.01.INTR.pdf", "media_type": "application/pdf"}], "date": "", "classification": ""}], "documents": [{"note": "Fiscal Note: HB1265.01.INTR.FN001", "links": [{"url": "https://api.iga.in.gov/2026/fis