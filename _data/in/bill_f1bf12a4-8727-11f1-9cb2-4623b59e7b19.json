{"legislative_session": "2026", "identifier": "SB 165", "title": "Hobart counter-cyclical fund loan.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["CITIES AND TOWNS; Generally", "COUNTIES; Lake", "ECONOMIC DEVELOPMENT", "FINANCIAL SERVICES; Bonds (Non-Judicial)", "FINANCIAL SERVICES; Loans and Mortgages", "STATE GOVERNMENT; Generally", "TAXES; Property Taxes"], "abstracts": [{"note": "Digest", "abstract": "Cancels a 2023 loan or loans from the state of Indiana from the counter-cyclical revenue and economic stabilization fund for the purpose of providing funds to be applied to refunding certain bonds of the city of Hobart and the city of Hobart redevelopment district and offsetting property tax revenue shortfalls incurred and to be incurred by the city of Hobart. Provides that the city of Hobart is not required to make any further payments to the state of Indiana in satisfaction of the loan or loans."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-sb165"}], "actions": [{"description": "Authored by Senator Spencer", "date": "2026-01-05", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "First reading: referred to Committee on Tax and Fiscal Policy", "date": "2026-01-05", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Tax and Fiscal Policy", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Mark Spencer", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Mark Spencer\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "Introduced Senate Bill (S)", "links": [{"url": "https://iga.in.gov/pdf-documents/124/2026/senate/bills/SB0165/SB0165.01.INTR.pdf", "media_type": "application/pdf"}], "date": "", "classification": ""}], "do