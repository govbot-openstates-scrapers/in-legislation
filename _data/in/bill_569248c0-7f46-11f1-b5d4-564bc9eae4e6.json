{"legislative_session": "2026", "identifier": "SB 192", "title": "Military protection order.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["ARMED FORCES; Generally", "CIVIL LAW AND PROCEDURE; Contracts and Legal Documents", "CIVIL LAW AND PROCEDURE; Rules of Trial Procedure", "COURTS; Generally"], "abstracts": [{"note": "Digest", "abstract": "Requires a party to a protective order proceeding to inform the court of any military protective orders issued by a military commander in effect between the parties. Allows a party to file a military protective order as evidence in a protective order proceeding and provides that the court may issue an ex parte protective order based upon this evidence."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-sb192"}], "actions": [{"description": "Authored by Senator Carrasco", "date": "2026-01-05", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "First reading: referred to Committee on Judiciary", "date": "2026-01-05", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Judiciary", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Cyndi Carrasco", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Cyndi Carrasco\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "Introduced Senate Bill (S)", "links": [{"url": "https://iga.in.gov/pdf-documents/124/2026/senate/bills/SB0192/SB0192.01.INTR.pdf", "media_type": "application/pdf"}], "date": "", "classification": ""}], "documents": [{"note": "Fiscal Note: SB0192.01.INTR.FN001", "links": [{"url": "https://api.iga.in.gov/2026/fiscal-notes/SB0192.01.INTR/SB0192.01.INTR.FN001?format=pdf", "media_type": "application/pdf"}], "date": "", "classification": "