{"legislative_session": "2026", "identifier": "HB 1110", "title": "PFAS chemicals.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["AGENCIES; Department of Environmental Management (IDEM)", "CIVIL LAW AND PROCEDURE; Liabilities, Damages, and Penalties", "ENVIRONMENT; Generally", "HEALTH; Local Boards and Programs"], "abstracts": [{"note": "Digest", "abstract": "Requires the department of environmental management to adopt maximum contaminant levels for PFAS chemicals and effluent limitation standards for wastewater containing PFAS chemicals by July 1, 2027. Creates various compliance requirements for direct dischargers and indirect dischargers. Establishes various civil penalties. Establishes the PFAS chemical testing and remediation fund. Creates a PFAS chemical grant program."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-hb1110"}], "actions": [{"description": "Authored by Representative Cash", "date": "2026-01-05", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "First reading: referred to Committee on Environmental Affairs", "date": "2026-01-05", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Environmental Affairs", "entity_type": "organization", "organization_id": null}]}, {"description": "Representatives Sweet, Bauer added as coauthors", "date": "2026-01-08", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name": "Becky Cash", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Becky Cash\"}", "organization_id": null}, {"name": "Lorissa Sweet", "classification": "coauthor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Lorissa Sweet\"}", "organization_id": null}, {"name": "Mau