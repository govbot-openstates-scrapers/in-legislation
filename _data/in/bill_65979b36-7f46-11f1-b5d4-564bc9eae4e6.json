{"legislative_session": "2026", "identifier": "SB 218", "title": "Circuit breaker credits for homesteads.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["CITIES AND TOWNS; Generally", "COUNTY GOVERNMENT", "TAXES; Food and Beverage Taxes", "TAXES; Innkeeper's Taxes", "TAXES; Local Income Taxes", "TAXES; Property Taxes", "UTILITIES; Electric"], "abstracts": [{"note": "Digest", "abstract": "Authorizes the fiscal body of a county, city, or town (municipality) to reduce its homestead property tax cap. Requires the reduced property tax cap to apply only in determining the net property tax revenue of the municipality that adopted it and not to any other taxing unit within the taxing district. Authorizes a municipality that has adopted a reduced homestead property tax cap to adopt any of the following local option taxes, either singly or in combination, the revenue from which must be used as property tax replacement revenue due to the reduced homestead property tax cap: (1) Local option sales tax. (2) Supplemental local income tax. (3) Supplemental innkeeper's tax. (4) Supplemental food and beverage tax. Makes conforming changes and removes obsolete provisions. Makes an appropriation."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-sb218"}], "actions": [{"description": "First reading: referred to Committee on Tax and Fiscal Policy", "date": "2026-01-08", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Tax and Fiscal Policy", "entity_type": "organization", "organization_id": null}]}, {"description": "Authored by Senators Buck, Niemeyer", "date": "2026-01-08", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name": "James Buck", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"James 