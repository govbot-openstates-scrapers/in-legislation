{"legislative_session": "2026", "identifier": "SB 113", "title": "Elections matters.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["CIVIL LAW AND PROCEDURE; Contracts and Legal Documents", "ELECTIONS; Generally", "LOCAL ELECTED OFFICIALS; County Clerk"], "abstracts": [{"note": "Digest", "abstract": "Requires each county election board to provide to the election division through a module of the computerized list, not later than 14 days after each election, the votes cast for each candidate and on each public question in each precinct at the last election. Requires the election division to promptly publish these election results on the website maintained by the election division. Specifies that starting on January 1, 2026, the period within which certain election material must be preserved is extended from 22 months to 34 months."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-sb113"}], "actions": [{"description": "Authored by Senator Schmitt", "date": "2025-12-09", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "First reading: referred to Committee on Elections", "date": "2025-12-09", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Elections", "entity_type": "organization", "organization_id": null}]}, {"description": "Senator Byrne added as second author", "date": "2026-01-05", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Committee report: amend do pass, adopted", "date": "2026-01-12", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["committee-passage"], "related_entities": []}, {"description": "Second reading: ordered engrossed", "date": "2026-01-15", "organization_id": "~{\"classification\": \"upper\"}", "classification": [