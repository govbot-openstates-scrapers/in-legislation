{"legislative_session": "2026", "identifier": "HB 1319", "title": "Collection of toll road user fees.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["AGENCIES; Department of Transportation (INDOT)", "AGENCIES; Generally", "TRANSPORTATION; Toll Roads and Bridges"], "abstracts": [{"note": "Digest", "abstract": "Requires the Indiana department of transportation to establish and implement an electronic or nonmanual tolling program as the sole means for charging and collecting user fees. Provides that a public-private agreement between the Indiana finance authority and an operator that is entered into, renewed, or amended after June 30, 2026, must contain a provision requiring the operator to establish and implement an electronic or nonmanual tolling program as the sole means for charging and collecting user fees."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-hb1319"}], "actions": [{"description": "Authored by Representative Jackson C", "date": "2026-01-06", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "First reading: referred to Committee on Roads and Transportation", "date": "2026-01-06", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Roads and Transportation", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Carolyn Jackson", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Carolyn Jackson\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "Introduced House Bill (H)", "links": [{"url": "https://iga.in.gov/pdf-documents/124/2026/house/bills/HB1319/HB1319.01.INTR.pdf", "media_type": "application/pdf"}], "date": "", "classification": ""}], "documents": [{"note": "Fiscal Note: HB1319.01.INTR.FN001", "links": [{"url"