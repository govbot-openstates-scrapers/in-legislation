{"legislative_session": "2026", "identifier": "SB 73", "title": "Masks at public assemblies.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["CRIMINAL LAW AND PROCEDURE; Creation of New Offenses", "CRIMINAL LAW AND PROCEDURE; Offenses Against Persons", "HEALTH; Generally"], "abstracts": [{"note": "Digest", "abstract": "Makes wearing a mask at a public assembly a Class C misdemeanor, and increases the penalty to a Class A misdemeanor for a second or subsequent offense. Provides a defense under certain circumstances. Increases the penalty for rioting and disorderly conduct to a Level 6 felony if the offense is committed while wearing a mask."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-sb73"}], "actions": [{"description": "Authored by Senator Byrne", "date": "2025-12-08", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "First reading: referred to Committee on Corrections and Criminal Law", "date": "2025-12-08", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Corrections and Criminal Law", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Gary Byrne", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Gary Byrne\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "Introduced Senate Bill (S)", "links": [{"url": "https://iga.in.gov/pdf-documents/124/2026/senate/bills/SB0073/SB0073.01.INTR.pdf", "media_type": "application/pdf"}], "date": "", "classification": ""}], "documents": [{"note": "Fiscal Note: SB0073.01.INTR.FN001", "links": [{"url": "https://api.iga.in.gov/2026/fiscal-notes/SB0073.01.INTR/SB0073.01.INTR.FN001?format=pdf", "media_type": "application/pdf"}], "date": "", "classification": ""}], "citations": [], "sourc