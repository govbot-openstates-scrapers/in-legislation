{"legislative_session": "2026", "identifier": "HB 1148", "title": "Same day voter registration.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["ELECTIONS; Voter Identification", "ELECTIONS; Voter Registration"], "abstracts": [{"note": "Digest", "abstract": "Permits an individual to register at the polls by completing a voter registration form and by providing proof of residence. Specifies that an individual may comply with the proof of residence requirement only by providing a REAL ID driver's license or identification card that shows the name and residence address of the individual registering to vote. Requires the ballot of a voter who registers at the polls to be treated as a provisional ballot."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-hb1148"}], "actions": [{"description": "First reading: referred to Committee on Elections and Apportionment", "date": "2026-01-05", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Elections and Apportionment", "entity_type": "organization", "organization_id": null}]}, {"description": "Authored by Representative Bartlett", "date": "2026-01-05", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Representative Pryor added as coauthor", "date": "2026-01-08", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name": "John Bartlett", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"John Bartlett\"}", "organization_id": null}, {"name": "Cherrish Pryor", "classification": "coauthor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Cherrish Pryor\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "Introduced House Bill (H)", "lin