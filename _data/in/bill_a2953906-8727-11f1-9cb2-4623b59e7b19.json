{"legislative_session": "2026", "identifier": "HB 1087", "title": "Overdose reversal medication.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["ADDICTION SERVICES; Illicit Drugs, Prescription Drugs, Substances, and Alcohol", "AGENCIES; Family and Social Services Administration (FSSA)", "HEALTH; Prescription Drugs and Medications", "SCHOOLS; Funds and Budgets", "SCHOOLS; Health and Safety Issues"], "abstracts": [{"note": "Digest", "abstract": "Provides that, subject to available funding, the division of mental health and addiction may develop an application to provide funds to a school corporation or school maintained by a school corporation to obtain a federal Food and Drug Administration approved opioid overdose reversal medication. Provides that the state health commissioner shall issue a statewide standing order, prescription, or protocol for a federal Food and Drug Administration approved opioid overdose reversal medication for each public school or school corporation."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-hb1087"}], "actions": [{"description": "Coauthored by Representatives Bascom, Pfaff", "date": "2026-01-05", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Authored by Representative Andrade", "date": "2026-01-05", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "First reading: referred to Committee on Public Health", "date": "2026-01-05", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Public Health", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Mike Andrade", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Mike Andrade\"}", "organization_id": nul