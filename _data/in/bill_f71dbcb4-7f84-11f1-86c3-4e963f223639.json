{"legislative_session": "2026", "identifier": "HB 1409", "title": "Mobile retail food establishment operations.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["AGENCIES; Department of Health (IDOH)", "RESTAURANTS AND LODGING", "TAXES; Food and Beverage Taxes"], "abstracts": [{"note": "Digest", "abstract": "Provides that provisions establishing a statewide mobile retail food establishment license may not be construed to prohibit an owner or operator of a mobile retail food establishment from complying with: (1) the collection and reporting requirements relating to food or beverage taxes; or (2) obtaining applicable municipal business permits or complying with municipal ordinances or requirements regulating the business operations of mobile retail food establishments."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-hb1409"}], "actions": [{"description": "First reading: referred to Committee on Public Health", "date": "2026-01-08", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Public Health", "entity_type": "organization", "organization_id": null}]}, {"description": "Authored by Representative King", "date": "2026-01-08", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name": "Joanna King", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Joanna King\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "Introduced House Bill (H)", "links": [{"url": "https://iga.in.gov/pdf-documents/124/2026/house/bills/HB1409/HB1409.01.INTR.pdf", "media_type": "application/pdf"}], "date": "", "classification": ""}], "documents": [{"note": "Fiscal Note: HB1409.01.INTR.FN001", "links": [{"url": "https://api.iga.in.gov/2026/fiscal-notes/HB1409.01.INTR/HB1409.01.INTR.FN001