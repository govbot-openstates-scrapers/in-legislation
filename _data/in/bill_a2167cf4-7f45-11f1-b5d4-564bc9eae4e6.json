{"legislative_session": "2026", "identifier": "HB 1389", "title": "Adoption and foster care matters.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["CHILDREN AND MINORS; Adoption", "CHILDREN AND MINORS; Foster Care", "CHURCHES AND RELIGIONS", "CIVIL RIGHTS", "STATE GOVERNMENT; Generally"], "abstracts": [{"note": "Digest", "abstract": "Prohibits a governmental entity from discriminating against a person in adoption and foster care matters based on the person's sincerely held religious belief, unless the discriminatory act as applied to the person is required to advance a compelling government interest and is the least restrictive means of advancing the interest. Specifies that a governmental entity may consider whether a person involved in adoption or foster care matters shares the same religion or faith tradition as a child or the child's parent when considering placement of a child. Allows a person to bring a cause of action against a governmental entity for discriminating against the person, or raise a violation as a claim or defense in a judicial proceeding, and allows for certain remedies. Provides that there is a two year statute of limitation for a discrimination claim."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-hb1389"}], "actions": [{"description": "Authored by Representative Lindauer", "date": "2026-01-08", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "First reading: referred to Committee on Judiciary", "date": "2026-01-08", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Judiciary", "entity_type": "organization", "organization_id": null}]}, {"description": "Representatives Jeter, DeVon, Heaton added as coauthors", "date": "2026-01-13", "organization_id": "~{\"classification\": \"lower\"}", "classification":