{"legislative_session": "2026", "identifier": "HB 1239", "title": "PFAS water safety standards.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["AGENCIES; Department of Health (IDOH)", "ENVIRONMENT; Hazardous Waste", "FEDERAL GOVERNMENT; Generally", "UTILITIES; Water"], "abstracts": [{"note": "Digest", "abstract": "Requires the Indiana department of health (state department) to establish state maximum contaminant levels for PFAS in water provided by public water systems. Provides that maximum contaminant levels established by the state department: (1) must be protective of public health, including the health of vulnerable subpopulations; and (2) may not be less stringent than any maximum contaminant level or health advisory promulgated by the United States Environmental Protection Agency."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-in-2026-hb1239"}], "actions": [{"description": "Authored by Representative Dvorak", "date": "2026-01-05", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "First reading: referred to Committee on Environmental Affairs", "date": "2026-01-05", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1", "referral-committee"], "related_entities": [{"name": "Environmental Affairs", "entity_type": "organization", "organization_id": null}]}, {"description": "Representative Hamilton added as coauthor", "date": "2026-01-13", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name": "Ryan Dvorak", "classification": "author", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Ryan Dvorak\"}", "organization_id": null}, {"name": "Carey Hamilton", "classification": "coauthor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Carey Hamilton\"}", "organization_id": null}], 